# Cleanup tmp pipeline directories older than 48 hours — runs daily at midnight UTC
# Removes /tmp/zolvra-pipeline/* directories older than 48h to free disk space.
#
# To install: crontab -e  (then add the line below)

0 0 * * * find /tmp/zolvra-pipeline -mindepth 1 -maxdepth 1 -type d -mtime +2 -exec rm -rf {} + 2>/dev/null || true
