# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Google AI (Imagen)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# kie.ai (Kling animation)
KIEAI_API_KEY=your-kieai-api-key

# ElevenLabs TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_NARRATOR_VOICE_ID=your-narrator-voice-id

# YouTube Data API v3
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# Pixabay
PIXABAY_API_KEY=your-pixabay-api-key

# ffmpeg
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# Anthropic (Claude for script gen + feedback engine)
ANTHROPIC_API_KEY=your-anthropic-api-key
